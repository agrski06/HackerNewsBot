# Required
HNB_TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
HNB_TELEGRAM_CHAT_ID=-1001234567890
HNB_OWNER_USER_ID=123456789

# Schedule (optional — overrides interval when set)
# Comma-separated times, e.g. "09:00,18:00"
# Can also be set at runtime via /schedule command in Telegram
HNB_SCHEDULE=
HNB_TIMEZONE=Europe/Berlin

# Optional (defaults shown)
HNB_FETCH_INTERVAL=30m
HNB_SCORE_THRESHOLD=100
HNB_MAX_STORIES_PER_RUN=5
HNB_DIGEST_MODE=false
HNB_SILENT_MESSAGES=true
HNB_DISABLE_PREVIEW=false
HNB_LOG_LEVEL=info
HNB_DB_PATH=seen.db
HNB_HEALTH_PORT=8080

# Telegraph Instant View (discussion pages)
HNB_TELEGRAPH_ENABLED=true
HNB_MAX_TOP_COMMENTS=15
HNB_MAX_COMMENT_DEPTH=3

